{
  "name": "optc-team-builder",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "data:import": "node ./scripts/import-optc-data.mjs",
    "data:import:all": "node ./scripts/import-optc-data.mjs --download-images=all",
    "data:import:glo-thumbs": "node ./scripts/import-optc-data.mjs --download-images=thumbnails-glo",
    "build:mobile": "npm run build && npx cap sync",
    "cap:sync": "npx cap sync",
    "cap:copy": "npx cap copy",
    "android:open": "npx cap open android",
    "ios:open": "npx cap open ios",
    "android:sync": "npx cap sync android",
    "ios:sync": "npx cap sync ios"
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/animations": "^21.2.3",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@ionic/angular": "^8.8.1",
    "ionicons": "^8.0.13",
    "rxjs": "~7.8.0",
    "sql.js": "^1.14.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
